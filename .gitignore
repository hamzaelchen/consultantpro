# ─────────────────────────────────────────
#  ConsultantPro — .gitignore
# ─────────────────────────────────────────

# ──── Node / React / Vite ────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# ──── Python / FastAPI ────
__pycache__/
*.py[cod]
*$py.class
*.so
backend/.env
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/*.egg-info/
backend/dist/
backend/build/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/htmlcov/
backend/.coverage
backend/coverage.xml
backend/logs/

# ──── PostgreSQL ────
*.sql.bak
*.dump

# ──── Docker ────
*.env.docker

# ──── OS ────
.DS_Store
Thumbs.db
desktop.ini

# ──── IDE / Editor ────
.vscode/
.idea/
*.swp
*.swo
*.orig
